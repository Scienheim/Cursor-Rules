│       └── Src/
│           └── app_comm.c
├── boards/
│   └── dev_kit_a/
│       └── board_notes.md          # 板级说明（示意）
├── BSP/
│   ├── Inc/
│   │   └── bsp_config.h
│   ├── usart/
│   │   ├── bsp_usart.h
│   │   └── bsp_usart.c
│   └── spi/
│       ├── bsp_spi.h
│       └── bsp_spi.c
├── Core/
│   ├── main.c
│   ├── gd32h7xx_it.c
│   ├── gd32h7xx_it.h
│   ├── sys.c
│   ├── sys.h
│   └── gd32h7xx_libopt.h
├── Docs/
│   ├── Design/
│   ├── API/
│   ├── architecture/
│   └── decisions/
├── Drivers/
